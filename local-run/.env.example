# Environment for the ResumeMatch MCP server (local-run/resumeMatch-map.py).
#
# NOTE: the server reads os.environ directly — it does NOT auto-load this file.
# Either `export` these in the shell that launches the server, or source them:
#   set -a; . local-run/.env; set +a
#   local-run/.venv/bin/mcp dev local-run/resumeMatch-map.py
# Copy to local-run/.env and fill in real values. Do not commit local-run/.env.

# API Gateway base URL — the same gateway the frontend uses.
# Reuse the value of VITE_API_BASE_URL from the project-root .env.
# No trailing slash needed (the server rstrips it); tool paths (/history, /analysis,
# /upload) are appended to this base.
RESUMEMATCH_API_BASE=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# Cognito ID token for the account whose data you want to read.
# MUST be the ID token, not the access token: while USE_SUB_IDENTITY is false the
# backend resolves identity from the token's `email` claim, which access tokens
# do not carry. Tokens expire (~1h) — re-paste a fresh one when calls start 401'ing.
# Get one from the live app while signed in: devtools -> Application -> Local Storage
# -> CognitoIdentityServiceProvider.<clientId>.<user>.idToken (or copy the `Bearer ...`
# value off any /history request). Local-dev shortcut only; the real fix is the OAuth
# resource-server flow noted in _bearer_token().
RESUMEMATCH_DEV_TOKEN=paste-a-cognito-id-token-here
